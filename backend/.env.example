APP_NAME=Wait Call API
DEBUG=false
CORS_ORIGINS=https://your-frontend.up.railway.app

# Railway MySQL을 연결하면 아래 MYSQL* 가 자동 주입되는 경우가 많습니다.
# 있으면 DATABASE_URL을 자동 조립합니다. (config.py)
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

# 또는 직접 URL
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:PORT/DB

# console | kakao_sms
NOTIFY_MODE=console

KAKAO_API_KEY=
KAKAO_SENDER_KEY=
KAKAO_TEMPLATE_WAITING=WAITING_REGISTERED
KAKAO_TEMPLATE_CALL=CALL_CUSTOMER

SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM=

DEFAULT_STORE_NAME=데모 매장
DEFAULT_STORE_SLUG=demo
